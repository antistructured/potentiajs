{
  "name": "potentia-js",
  "version": "0.0.1",
  "private": true,
  "description": "Experimental, contract-driven JavaScript framework kernel.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/index.js",
    "src/kernel/",
    "examples/kernel-basic/",
    "examples/sigiljs-basic/",
    "examples/composed-basic/",
    "examples/action-basic/",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "check": "bun test",
    "pack:dry": "npm pack --dry-run --json",
    "check:preview": "bun run test && bun run check && npm pack --dry-run --json",
    "check:file-routing": "bun test tests/file-routing-*.test.js",
    "generate:file-routes": "bun scripts/generate-file-routes.js"
  },
  "keywords": [
    "bun",
    "javascript",
    "framework",
    "contracts",
    "sigiljs",
    "routing"
  ],
  "author": "Daniel Weipert",
  "license": "UNLICENSED",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@weipertda/sigiljs": "0.18.0"
  },
  "devDependencies": {}
}
