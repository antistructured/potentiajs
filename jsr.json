{
  "name": "@potentiajs/core",
  "version": "0.2.0-preview.0",
  "license": "MIT",
  "exports": {
    ".": "./src/index.js",
    "./file-routing": "./src/file-routing.js",
    "./forms": "./src/forms.js",
    "./html": "./src/html.js"
  },
  "publish": {
    "include": [
      "src/**/*.js",
      "src/**/*.d.ts",
      "README.md",
      "LICENSE",
      "package.json"
    ],
    "exclude": [
      ".github",
      "docs",
      "tests",
      "examples",
      "plugins",
      "scripts",
      "cli",
      ".potentia",
      "bun.lock",
      "*.mjs",
      "*.view"
    ]
  }
}
