{
  "name": "@potentiajs/core",
  "version": "0.2.0-preview.1",
  "private": false,
  "description": "JavaScript framework kernel for contract-driven routing, actions, and form metadata.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "potentia": "./bin/potentia.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./file-routing": {
      "types": "./src/file-routing.d.ts",
      "import": "./src/file-routing.js"
    },
    "./forms": {
      "types": "./src/forms.d.ts",
      "import": "./src/forms.js"
    },
    "./html": {
      "types": "./src/html.d.ts",
      "import": "./src/html.js"
    }
  },
  "files": [
    "bin/",
    "src/",
    "examples/file-routing-basic/",
    "examples/full-flow-basic/",
    "examples/form-rendering-basic/",
    "examples/html-basic/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "check": "bun test",
    "pack:dry": "npm pack --dry-run --json",
    "check:preview": "bun run test && bun run check && npm pack --dry-run --json",
    "check:release": "bun run check:preview",
    "check:file-routing": "bun test tests/file-routing-*.test.js",
    "generate:file-routes": "bun scripts/generate-file-routes.js"
  },
  "keywords": [
    "actions",
    "bun",
    "contracts",
    "effects",
    "form-projection",
    "form-state",
    "forms",
    "framework",
    "full-stack",
    "functional-core",
    "javascript",
    "metadata",
    "plain-javascript",
    "router",
    "routing",
    "runtime-contracts",
    "server-actions",
    "server-framework",
    "sigiljs",
    "validation",
    "web-framework"
  ],
  "author": "Daniel Weipert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antistructured/potentiajs.git"
  },
  "bugs": {
    "url": "https://github.com/antistructured/potentiajs/issues"
  },
  "homepage": "https://github.com/antistructured/potentiajs#readme",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@weipertda/sigiljs": "0.18.0"
  },
  "devDependencies": {}
}
